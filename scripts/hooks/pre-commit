#!/usr/bin/env bash
# pre-commit: 对 staged 的 Markdown 文件运行 markdownlint --fix
# 如果有自动修复发生，把修复后的内容重新加入 staging，并提示用户复核

set -e

# 1. 找出本次提交里被修改的 .md 文件（去掉已删除的）
#    用 while read 而非 mapfile，兼容 macOS 自带的 bash 3.2
md_files=()
while IFS= read -r -d '' f; do
  case "$f" in
    *.md) md_files+=("$f") ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACM -z)

if [ ${#md_files[@]} -eq 0 ]; then
  exit 0
fi

echo "[pre-commit] markdownlint-cli2 --fix on ${#md_files[@]} file(s)..."

# 2. 记录修复前 hash（用并行数组，兼容老 bash）
pre_files=()
pre_hashes=()
for f in "${md_files[@]}"; do
  pre_files+=("$f")
  pre_hashes+=("$(git hash-object "$f" 2>/dev/null || true)")
done

# 3. 跑 --fix
if ! npx --yes markdownlint-cli2 --fix "${md_files[@]}"; then
  echo
  echo "[pre-commit] ❌ markdownlint 有无法自动修复的错误，提交被阻断。"
  echo "[pre-commit] 请手动处理上面列出的问题后重新 git add && git commit。"
  exit 1
fi

# 4. 检查哪些文件被自动修复了，自动 re-add
changed=()
i=0
for f in "${pre_files[@]}"; do
  new_hash=$(git hash-object "$f" 2>/dev/null || true)
  if [ "${pre_hashes[$i]}" != "$new_hash" ]; then
    changed+=("$f")
    git add "$f"
  fi
  i=$((i + 1))
done

if [ ${#changed[@]} -gt 0 ]; then
  echo
  echo "[pre-commit] ✅ 已自动修复并 re-add 以下文件："
  for f in "${changed[@]}"; do
    echo "  - $f"
  done
  echo "[pre-commit] 修复后的版本已纳入本次提交。"
fi

exit 0
